# === 评测 LLM 配置 ===
# SII_PE_API_KEYS=sk-key1,sk-key2,sk-key3
# SII_PE_API_BASE_URL=https://api.deepseek.com
# SII_PE_MODEL=deepseek-chat
# SII_PE_DATA_PATH=./data/val.jsonl

# === 优化器 LLM 配置（独立 provider，应选最强模型）===
# 未配置时自动 fallback 到评测的 api_keys + api_base_url
# SII_PE_OPTIMIZER_API_KEYS=sk-opt-key1
# SII_PE_OPTIMIZER_API_BASE_URL=https://api.openai.com/v1
# SII_PE_OPTIMIZER_MODEL=gpt-4o
