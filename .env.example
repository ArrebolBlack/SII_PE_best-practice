# === 配置方式 ===
# 推荐方式：编辑 config.yaml（cp config.example.yaml config.yaml）
#
# 环境变量方式（适用于 CI/CD，会覆盖 config.yaml 中的值）：

# 评测 LLM
# SII_PE_API_KEYS=sk-key1,sk-key2,sk-key3
# SII_PE_API_BASE_URL=https://api.deepseek.com
# SII_PE_MODEL=deepseek-chat
# SII_PE_DATA_PATH=./data/val.jsonl

# 优化器 LLM（可选，不设则复用评测配置）
# SII_PE_OPTIMIZER_API_KEYS=sk-anthropic-key
# SII_PE_OPTIMIZER_API_BASE_URL=https://api.anthropic.com/v1
# SII_PE_OPTIMIZER_MODEL=claude-opus-4-6
